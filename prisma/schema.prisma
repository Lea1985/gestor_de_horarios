generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ENUMS

enum Estado {
  ACTIVO
  INACTIVO
  SUSPENDIDO
}

enum TipoUnidad {
  AULA
  LABORATORIO
  ADMIN
  OTRA
}

enum Dias {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
  SABADO
  DOMINGO
}

enum EstadoClase {
  PROGRAMADA
  DICTADA
  SUSPENDIDA
  REEMPLAZADA
}

/// ENTIDADES PRINCIPALES

model Usuario {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  nombre       String?
  esSuperAdmin Boolean  @default(false)
  estado       Estado   @default(ACTIVO)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roles    UsuarioRol[]
  sesiones Sesion[]
}

model Rol {
  id          Int      @id @default(autoincrement())
  nombre      String
  descripcion String?
  createdAt   DateTime @default(now())

  usuarios UsuarioRol[]
}

model UsuarioRol {
  usuarioId     Int
  rolId         Int
  institucionId Int

  usuario     Usuario     @relation(fields: [usuarioId], references: [id])
  rol         Rol         @relation(fields: [rolId], references: [id])
  institucion Institucion @relation(fields: [institucionId], references: [id])

  @@id([usuarioId, rolId, institucionId])
  @@index([usuarioId])
  @@index([institucionId])
}

model Sesion {
  id            Int      @id @default(autoincrement())
  usuarioId     Int
  institucionId Int
  token         String   @unique
  ip            String?
  userAgent     String?
  createdAt     DateTime @default(now())
  expiresAt     DateTime

  usuario     Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  institucion Institucion @relation(fields: [institucionId], references: [id])

  @@index([expiresAt])
  @@index([usuarioId, institucionId])
}

model Institucion {
  id            Int       @id @default(autoincrement())
  nombre        String
  dominio       String?   @unique
  configuracion Json?
  domicilio     String?
  telefono      String?
  email         String?
  cuit          String?   @unique
  estado        Estado    @default(ACTIVO)
  activo        Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  unidades      UnidadOrganizativa[]
  modulos       ModuloHorario[]
  agentes       Agente[]
  asignaciones  Asignacion[]
  usuariosRoles UsuarioRol[]
  codigarios    Codigario[]
  materias      Materia[]
  sesiones      Sesion[]

  turnos     Turno[]
  cursos     Curso[]
  comisiones Comision[]

  distribucionesHorarias DistribucionHoraria[] @relation("DistribucionHoraria_Institucion")
  horariosAsignados      HorarioAsignado[]     @relation("HorarioAsignado_Institucion")
  ClaseProgramada        ClaseProgramada[]
  CalendarioEscolar      CalendarioEscolar[]
  titularidades          TitularAsignacion[]

  @@index([estado])
  @@index([activo])
  @@index([cuit])
  @@index([deletedAt])
}

model Agente {
  id            Int       @id @default(autoincrement())
  institucionId Int
  nombre        String
  apellido      String
  documento     String
  email         String?
  telefono      String?
  domicilio     String?
  estado        Estado    @default(ACTIVO)
  activo        Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  institucion       Institucion         @relation(fields: [institucionId], references: [id])
  horariosAsignados HorarioAsignado[]   @relation("HorarioAsignado_Agente")
  titularidades     TitularAsignacion[]

  @@unique([institucionId, documento])
  @@index([institucionId])
  @@index([activo])
  @@index([deletedAt])
}

model UnidadOrganizativa {
  id            Int         @id @default(autoincrement())
  institucionId Int
  codigoUnidad  Int
  nombre        String
  tipo          TipoUnidad?
  estado        Estado      @default(ACTIVO)
  activo        Boolean     @default(true)
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  asignaciones    Asignacion[]
  institucion     Institucion       @relation(fields: [institucionId], references: [id])
  ClaseProgramada ClaseProgramada[]
  comisiones      Comision[]

  @@unique([institucionId, codigoUnidad])
  @@index([institucionId])
  @@index([activo])
  @@index([deletedAt])
}

/// TURNO
/// horaInicio y horaFin como minutos desde medianoche (0-1439).

model Turno {
  id            Int       @id @default(autoincrement())
  institucionId Int
  nombre        String
  horaInicio    Int
  horaFin       Int
  activo        Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  institucion  Institucion     @relation(fields: [institucionId], references: [id])
  modulos      ModuloHorario[]
  asignaciones Asignacion[]
  comisiones   Comision[]

  @@unique([institucionId, nombre])
  @@index([institucionId])
  @@index([activo])
  @@index([deletedAt])
}

model Curso {
  id            Int       @id @default(autoincrement())
  institucionId Int
  nombre        String
  descripcion   String?
  activo        Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  institucion Institucion @relation(fields: [institucionId], references: [id])
  comisiones  Comision[]
  materias    Materia[]

  @@unique([institucionId, nombre])
  @@index([institucionId])
  @@index([activo])
  @@index([deletedAt])
}

model Comision {
  id            Int       @id @default(autoincrement())
  institucionId Int
  cursoId       Int
  turnoId       Int
  unidadId      Int?
  nombre        String
  descripcion   String?
  activo        Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  institucion Institucion         @relation(fields: [institucionId], references: [id])
  curso       Curso               @relation(fields: [cursoId], references: [id])
  turno       Turno               @relation(fields: [turnoId], references: [id])
  unidad      UnidadOrganizativa? @relation(fields: [unidadId], references: [id])

  asignaciones    Asignacion[]
  ClaseProgramada ClaseProgramada[]

  @@unique([cursoId, nombre])
  @@index([institucionId])
  @@index([cursoId])
  @@index([turnoId])
  @@index([unidadId])
  @@index([activo])
  @@index([deletedAt])
}

model Asignacion {
  id                       Int       @id @default(autoincrement())
  institucionId            Int
  // agenteId eliminado: el titular vigente vive exclusivamente en TitularAsignacion.
  // Un cargo puede estar vacante (sin ningún TitularAsignacion asociado).
  unidadId                 Int
  identificadorEstructural String
  fecha_inicio             DateTime
  fecha_fin                DateTime?
  estado                   Estado    @default(ACTIVO)
  activo                   Boolean   @default(true)
  deletedAt                DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  materiaId  Int?
  comisionId Int?
  turnoId    Int

  institucion Institucion        @relation(fields: [institucionId], references: [id])
  unidad      UnidadOrganizativa @relation(fields: [unidadId], references: [id])
  materia     Materia?           @relation(fields: [materiaId], references: [id])
  comision    Comision?          @relation(fields: [comisionId], references: [id])
  turno       Turno              @relation(fields: [turnoId], references: [id])

  distribuciones    DistribucionHoraria[]
  incidencias       Incidencia[]
  horariosAsignados HorarioAsignado[]     @relation("HorarioAsignado_Asignacion")

  reemplazosTitular  Reemplazo[]         @relation("TitularReemplazo")
  reemplazosSuplente Reemplazo[]         @relation("SuplenteReemplazo")
  ClaseProgramada    ClaseProgramada[]
  titularidades      TitularAsignacion[]

  @@unique([institucionId, identificadorEstructural])
  @@index([institucionId])
  @@index([institucionId, unidadId, fecha_inicio, fecha_fin])
  // Los índices que incluían agenteId se eliminan junto con el campo.
  // Las queries "cargos de un agente" ahora pasan por TitularAsignacion.
  @@index([comisionId])
  @@index([turnoId])
  @@index([activo])
  @@index([deletedAt])
}

/// TitularAsignacion
/// Historial de personas que ocuparon un cargo (Asignacion).
/// El titular vigente es el registro con activo = true y fecha_hasta = null.
/// Un cargo sin ningún registro es un cargo vacante.

model TitularAsignacion {
  id            Int       @id @default(autoincrement())
  institucionId Int
  asignacionId  Int
  agenteId      Int
  fecha_desde   DateTime
  fecha_hasta   DateTime?
  activo        Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  institucion Institucion @relation(fields: [institucionId], references: [id])
  asignacion  Asignacion  @relation(fields: [asignacionId], references: [id], onDelete: Cascade)
  agente      Agente      @relation(fields: [agenteId], references: [id])

  @@index([institucionId])
  @@index([asignacionId])
  @@index([agenteId])
  @@index([institucionId, asignacionId])
  @@index([institucionId, agenteId])
  @@index([activo])
  @@index([deletedAt])
  @@index([asignacionId, fecha_desde, fecha_hasta])
  // Índice clave para resolver "titular vigente de un cargo" eficientemente
  @@index([asignacionId, activo, fecha_hasta])
}

model ModuloHorario {
  id            Int       @id @default(autoincrement())
  institucionId Int
  dia_semana    Dias
  hora_desde    Int
  hora_hasta    Int
  turnoId       Int?
  activo        Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  institucion       Institucion          @relation(fields: [institucionId], references: [id])
  turno             Turno?               @relation(fields: [turnoId], references: [id])
  distribuciones    DistribucionModulo[]
  horariosAsignados HorarioAsignado[]    @relation("HorarioAsignado_ModuloHorario")
  ClaseProgramada   ClaseProgramada[]

  @@unique([institucionId, dia_semana, hora_desde, hora_hasta])
  @@index([institucionId])
  @@index([dia_semana, hora_desde, hora_hasta])
  @@index([turnoId])
  @@index([activo])
  @@index([institucionId, dia_semana])
}

model DistribucionHoraria {
  id                   Int       @id @default(autoincrement())
  institucionId        Int
  asignacionId         Int
  version              Int
  fecha_vigencia_desde DateTime
  fecha_vigencia_hasta DateTime?
  estado               Estado    @default(ACTIVO)
  activo               Boolean   @default(true)
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  asignacion          Asignacion           @relation(fields: [asignacionId], references: [id], onDelete: Cascade)
  distribucionModulos DistribucionModulo[]
  institucion         Institucion          @relation(fields: [institucionId], references: [id], name: "DistribucionHoraria_Institucion")
  horariosAsignados   HorarioAsignado[]    @relation("DistribucionHoraria_HorarioAsignado")

  @@unique([asignacionId, version])
  @@index([asignacionId])
  @@index([institucionId])
  @@index([estado, fecha_vigencia_desde, fecha_vigencia_hasta])
  @@index([activo])
  @@index([deletedAt])
}

model DistribucionModulo {
  distribucionHorariaId Int
  moduloHorarioId       Int
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  distribucionHoraria DistribucionHoraria @relation(fields: [distribucionHorariaId], references: [id], onDelete: Cascade)
  moduloHorario       ModuloHorario       @relation(fields: [moduloHorarioId], references: [id])

  @@id([distribucionHorariaId, moduloHorarioId])
  @@index([moduloHorarioId])
}

model Incidencia {
  id              Int       @id @default(autoincrement())
  asignacionId    Int
  fecha_desde     DateTime
  fecha_hasta     DateTime
  codigarioItemId Int
  observacion     String?
  activo          Boolean   @default(true)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  incidenciaPadreId Int?
  padre             Incidencia?  @relation("incidenciaPadre", fields: [incidenciaPadreId], references: [id])
  hijos             Incidencia[] @relation("incidenciaPadre")

  asignacion      Asignacion        @relation(fields: [asignacionId], references: [id], onDelete: Cascade)
  codigarioItem   CodigarioItem     @relation(fields: [codigarioItemId], references: [id])
  ClaseProgramada ClaseProgramada[]

  @@unique([asignacionId, fecha_desde], name: "asignacionId_fecha_desde")
  @@index([asignacionId])
  @@index([codigarioItemId, fecha_desde])
  @@index([fecha_desde, fecha_hasta])
  @@index([asignacionId, fecha_desde])
  @@index([activo])
  @@index([deletedAt])
}

/// HorarioAsignado
/// agenteId es un snapshot del titular al momento de crear el horario.
/// No se actualiza si cambia el titular; sirve para trazabilidad histórica.
/// Para saber quién cubre un módulo hoy, combinar con TitularAsignacion.

model HorarioAsignado {
  id                    Int      @id @default(autoincrement())
  institucionId         Int
  agenteId              Int // snapshot: titular vigente al momento de asignar
  asignacionId          Int
  distribucionHorariaId Int
  moduloHorarioId       Int
  createdAt             DateTime @default(now())

  institucion         Institucion         @relation(fields: [institucionId], references: [id], name: "HorarioAsignado_Institucion")
  agente              Agente              @relation(fields: [agenteId], references: [id], name: "HorarioAsignado_Agente")
  distribucionHoraria DistribucionHoraria @relation(fields: [distribucionHorariaId], references: [id], name: "DistribucionHoraria_HorarioAsignado")
  moduloHorario       ModuloHorario       @relation(fields: [moduloHorarioId], references: [id], name: "HorarioAsignado_ModuloHorario")
  asignacion          Asignacion          @relation(fields: [asignacionId], references: [id], onDelete: Cascade, name: "HorarioAsignado_Asignacion")

  @@unique([distribucionHorariaId, moduloHorarioId])
  @@index([institucionId, agenteId])
  @@index([institucionId, moduloHorarioId])
  @@index([institucionId, asignacionId])
  @@index([institucionId, distribucionHorariaId])
  @@index([institucionId, agenteId, moduloHorarioId])
}

model ClaseProgramada {
  id            Int         @id @default(autoincrement())
  institucionId Int
  asignacionId  Int
  moduloId      Int
  unidadId      Int
  comisionId    Int?
  fecha         DateTime
  estado        EstadoClase @default(PROGRAMADA)
  incidenciaId  Int?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  institucion Institucion        @relation(fields: [institucionId], references: [id])
  asignacion  Asignacion         @relation(fields: [asignacionId], references: [id])
  modulo      ModuloHorario      @relation(fields: [moduloId], references: [id])
  unidad      UnidadOrganizativa @relation(fields: [unidadId], references: [id])
  comision    Comision?          @relation(fields: [comisionId], references: [id])
  incidencia  Incidencia?        @relation(fields: [incidenciaId], references: [id])

  reemplazos Reemplazo[]

  @@unique([asignacionId, moduloId, fecha], name: "asignacionId_moduloId_fecha")
  @@index([fecha])
  @@index([institucionId, fecha])
  @@index([asignacionId])
  @@index([moduloId])
  @@index([comisionId, fecha])
}

model Reemplazo {
  id                   Int       @id @default(autoincrement())
  claseId              Int
  asignacionTitularId  Int
  asignacionSuplenteId Int
  observacion          String?
  activo               Boolean   @default(true)
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())

  clase              ClaseProgramada @relation(fields: [claseId], references: [id])
  asignacionTitular  Asignacion      @relation("TitularReemplazo", fields: [asignacionTitularId], references: [id])
  asignacionSuplente Asignacion      @relation("SuplenteReemplazo", fields: [asignacionSuplenteId], references: [id])

  @@unique([claseId, asignacionSuplenteId], name: "claseId_asignacionSuplenteId")
  @@index([claseId])
  @@index([asignacionTitularId])
  @@index([asignacionSuplenteId])
  @@index([activo])
  @@index([deletedAt])
}

model CalendarioEscolar {
  id             Int      @id @default(autoincrement())
  institucionId  Int
  fecha          DateTime
  descripcion    String
  esFeriado      Boolean  @default(false)
  suspendeClases Boolean  @default(false)
  createdAt      DateTime @default(now())

  institucion Institucion @relation(fields: [institucionId], references: [id])

  @@index([institucionId, fecha])
}

model Codigario {
  id            Int       @id @default(autoincrement())
  institucionId Int
  nombre        String
  descripcion   String?
  activo        Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  institucion Institucion     @relation(fields: [institucionId], references: [id])
  items       CodigarioItem[]

  @@unique([institucionId, nombre])
  @@index([institucionId])
  @@index([institucionId, activo])
  @@index([deletedAt])
}

model CodigarioItem {
  id          Int       @id @default(autoincrement())
  codigarioId Int
  codigo      String
  nombre      String
  descripcion String?
  activo      Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  codigario   Codigario    @relation(fields: [codigarioId], references: [id])
  incidencias Incidencia[]

  @@unique([codigarioId, codigo])
  @@index([codigarioId])
  @@index([activo])
  @@index([deletedAt])
}

model Materia {
  id            Int       @id @default(autoincrement())
  institucionId Int
  cursoId       Int?
  nombre        String
  activo        Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  institucion  Institucion  @relation(fields: [institucionId], references: [id])
  curso        Curso?       @relation(fields: [cursoId], references: [id])
  asignaciones Asignacion[]

  @@unique([cursoId, nombre])
  @@index([institucionId])
  @@index([cursoId])
}
